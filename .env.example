# API key (required - used as fallback for all platforms)
# Get yours at: https://platform.deepseek.com/api_keys
CLAWAGENT_API_KEY=sk-....

# Available models:
# - deepseek-v4-pro   (stronger, 1.6T params)
# - deepseek-v4-flash (faster/cheaper, 284B params)
# Default is deepseek-v4-flash
# CLAWAGENT_MODEL=deepseek-v4-flash

# ─── Multi-Platform Support ──────────────────────────────
# Switch platforms via /platform command or CLAWAGENT_PLATFORM env var.
# Each platform has its own API key env var and endpoint.
#
# Platform: deepseek (default, OpenAI-compatible)
# CLAWAGENT_PLATFORM=deepseek
# CLAWAGENT_MODEL=deepseek-chat
# (CLAWAGENT_API_KEY is used as fallback if DEEPSEEK_API_KEY is not set)
#
# Platform: ark (火山方舟, OpenAI-compatible)
# Get yours at: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# ARK_API_KEY=ark-your-ark-key
# CLAWAGENT_PLATFORM=ark
# CLAWAGENT_MODEL=doubao-seed-2-0-pro-260215
#
# Platform: opencode-go (OpenCode Go, OpenAI-compatible)
# OPENCODE_GO_API_KEY=your-opencode-go-key
# CLAWAGENT_PLATFORM=opencode-go
# CLAWAGENT_MODEL=glm-5.2
#
# Platform: openai (direct OpenAI API)
# OPENAI_API_KEY=sk-your-openai-key
# CLAWAGENT_PLATFORM=openai
# CLAWAGENT_MODEL=gpt-4o
#
# Custom API base (overrides platform preset if set):
# CLAWAGENT_API_BASE=https://your-custom-endpoint.com/v1

# SiliconFlow Embedding API (optional, for RAG)
# Get yours at: https://siliconflow.cn
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/embeddings
# SILICONFLOW_MODEL=Qwen/Qwen3-VL-Embedding-8B
# SILICONFLOW_DIMENSIONS=768

# ─── Multi-Agent Worker Configuration ──────────────────
# Workers are sub-agents the Orchestrator delegates tasks to.
# Each worker can use a different model/provider.

# Common defaults (fallback for all workers)
WORKER_COMMON_MODEL=deepseek-v4-flash
WORKER_COMMON_MODEL_PROVIDER=openai
# WORKER_COMMON_MAX_TOKENS=4096
# WORKER_COMMON_TEMPERATURE=0.0
# WORKER_COMMON_API_KEY=           # fallback: CLAWAGENT_API_KEY

# Coder Worker (code writing/debugging - deepseek-v4-flash)
# WORKER_CODER_MODEL=deepseek-v4-flash
# WORKER_CODER_MODEL_PROVIDER=openai

# Researcher Worker (info retrieval - qwen via SiliconFlow)
# WORKER_RESEARCHER_MODEL=Qwen/Qwen3-235B-A22B
# WORKER_RESEARCHER_MODEL_PROVIDER=openai
# WORKER_RESEARCHER_API_BASE=https://api.siliconflow.cn/v1
# WORKER_RESEARCHER_API_KEY=       # your SiliconFlow key

# Critic Worker (code review - qwen via SiliconFlow)
# WORKER_CRITIC_MODEL=Qwen/Qwen3-235B-A22B
# WORKER_CRITIC_MODEL_PROVIDER=openai
# WORKER_CRITIC_API_BASE=https://api.siliconflow.cn/v1
# WORKER_CRITIC_API_KEY=           # your SiliconFlow key

# Writer Worker (document generation - deepseek-v4-flash)
# WORKER_WRITER_MODEL=deepseek-v4-flash
# WORKER_WRITER_MODEL_PROVIDER=openai

# ─── Context Compression ─────────────────────────────────
# Compress message history before passing to LLM to avoid
# exceeding the context window during long conversations.
# Strategies: trim / token_trim / summarize
# - trim: keep last N messages (fastest, default)
# - token_trim: keep messages within token budget
# - summarize: LLM-based conversation summarization (slow, best quality)
# COMPRESSION_STRATEGY=trim
# COMPRESSION_MAX_MESSAGES=40
# COMPRESSION_MAX_TOKENS=80000
# COMPRESSION_KEEP_RECENT=6

# ─── Gateway / Multi-Platform ────────────────────────────
# WeChat iLink Bot (个人微信)
# First run: terminal shows QR code -> scan with WeChat to login.
# Credentials saved to ilink_creds.json for subsequent runs.
# WECHAT_ILINK_ENABLED=true
# WECHAT_ILINK_CREDS=ilink_creds.json

# ─── RAG BM25 Cache Security ─────────────────────────────
# HMAC secret to sign BM25 index cache, preventing tampering.
# Leave empty to disable signing (cache still works but is unverified).
# CLAWAGENT_BM25_CACHE_SECRET=your-random-secret-here
