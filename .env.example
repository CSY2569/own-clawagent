# DeepSeek API key (required)
# Get yours at: https://platform.deepseek.com/api_keys
ANTHROPIC_API_KEY=sk-....

# DeepSeek Anthropic-compatible API base URL
# If using official DeepSeek:
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Available models:
# - deepseek-v4-pro   (stronger, 1.6T params)
# - deepseek-v4-flash (faster/cheaper, 284B params)
# Default is deepseek-v4-flash
# CLAWAGENT_MODEL=deepseek-v4-flash

# SiliconFlow Embedding API (optional, for RAG)
# Get yours at: https://siliconflow.cn
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/embeddings
# SILICONFLOW_MODEL=Qwen/Qwen3-VL-Embedding-8B
# SILICONFLOW_DIMENSIONS=768

# ─── Multi-Agent Worker Configuration ──────────────────
# Workers are sub-agents the Orchestrator delegates tasks to.
# Each worker can use a different model/provider.

# Common defaults (fallback for all workers)
# WORKER_COMMON_MODEL=deepseek-v4-flash
# WORKER_COMMON_MODEL_PROVIDER=anthropic
# WORKER_COMMON_MAX_TOKENS=4096
# WORKER_COMMON_TEMPERATURE=0.0
# WORKER_COMMON_API_KEY=           # fallback: ANTHROPIC_API_KEY

# Coder Worker (code writing/debugging — deepseek-v4-flash)
# WORKER_CODER_MODEL=deepseek-v4-flash
# WORKER_CODER_MODEL_PROVIDER=anthropic

# Researcher Worker (info retrieval — qwen via SiliconFlow)
# WORKER_RESEARCHER_MODEL=Qwen/Qwen3-235B-A22B
# WORKER_RESEARCHER_MODEL_PROVIDER=openai
# WORKER_RESEARCHER_API_BASE=https://api.siliconflow.cn/v1
# WORKER_RESEARCHER_API_KEY=       # your SiliconFlow key

# Critic Worker (code review — qwen via SiliconFlow)
# WORKER_CRITIC_MODEL=Qwen/Qwen3-235B-A22B
# WORKER_CRITIC_MODEL_PROVIDER=openai
# WORKER_CRITIC_API_BASE=https://api.siliconflow.cn/v1
# WORKER_CRITIC_API_KEY=           # your SiliconFlow key

# Writer Worker (document generation — deepseek-v4-flash)
# WORKER_WRITER_MODEL=deepseek-v4-flash
# WORKER_WRITER_MODEL_PROVIDER=anthropic

# ─── Context Compression ─────────────────────────────────
# Compress message history before passing to LLM to avoid
# exceeding the context window during long conversations.
# Strategies: trim / token_trim / summarize (not yet implemented)
# COMPRESSION_STRATEGY=trim
# COMPRESSION_MAX_MESSAGES=40
# COMPRESSION_MAX_TOKENS=80000
# COMPRESSION_KEEP_RECENT=6
