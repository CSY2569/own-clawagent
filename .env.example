# DeepSeek API key (required)
# Get yours at: https://platform.deepseek.com/api_keys
ANTHROPIC_API_KEY=sk-....

# DeepSeek Anthropic-compatible API base URL
# If using official DeepSeek:
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Available models:
# - deepseek-v4-pro   (stronger, 1.6T params)
# - deepseek-v4-flash (faster/cheaper, 284B params)
# Default is deepseek-v4-flash
# CLAWAGENT_MODEL=deepseek-v4-flash

# SiliconFlow Embedding API (optional, for RAG)
# Get yours at: https://siliconflow.cn
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/embeddings
# SILICONFLOW_MODEL=Qwen/Qwen3-VL-Embedding-8B
# SILICONFLOW_DIMENSIONS=768
