# ============================================================
# clawagent 环境配置
# ============================================================
#
# 快速开始（仅需 1 个变量）：
#   1. 填 CLAWAGENT_API_KEY（从 https://platform.deepseek.com/api_keys 获取）
#   2. uv run clawagent
#
# 常用命令：
#   /model         — 交互式选模型
#   /models        — 列出可用模型
#   /platform      — 切换平台（deepseek/ark/opencode-go/openai/anthropic）
#   /permissions   — 查看/修改工具权限
#   /forget all    — 清除长期记忆
#   /help          — 帮助
#
# ============================================================


# ─── 1. 必填 ────────────────────────────────────────────────

# API 密钥（所有平台的回退密钥）
# 获取地址：https://platform.deepseek.com/api_keys
CLAWAGENT_API_KEY=sk-....


# ─── 2. 平台与模型 ─────────────────────────────────────────
#
# 每个平台有独立的密钥环境变量和 API 端点。
# CLAWAGENT_API_KEY 是所有平台未配密钥时的回退。
#
# 默认平台：deepseek（OpenAI 兼容接口）
# CLAWAGENT_PLATFORM=deepseek
# CLAWAGENT_MODEL=deepseek-v4-flash

# --- DeepSeek（默认） ---
# 端点：https://api.deepseek.com/v1
# 密钥：DEEPSEEK_API_KEY（未设置时回退到 CLAWAGENT_API_KEY）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# CLAWAGENT_PLATFORM=deepseek
# CLAWAGENT_MODEL=deepseek-chat

# --- 火山方舟 Ark ---
# 端点：https://ark.cn-beijing.volces.com/api/v3
# 密钥获取：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# ARK_API_KEY=ark-your-ark-key
# CLAWAGENT_PLATFORM=ark
# CLAWAGENT_MODEL=doubao-seed-2-0-pro-260215

# --- OpenCode Go ---
# 端点：https://opencode.ai/zen/go/v1
# 可用模型：/models 命令自动拉取（无需密钥）
# OPENCODE_GO_API_KEY=your-opencode-go-key
# CLAWAGENT_PLATFORM=opencode-go
# CLAWAGENT_MODEL=glm-5.2

# --- OpenAI ---
# 端点：https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-openai-key
# CLAWAGENT_PLATFORM=openai
# CLAWAGENT_MODEL=gpt-4o

# --- Anthropic ---
# 端点：https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# CLAWAGENT_PLATFORM=anthropic
# CLAWAGENT_MODEL=claude-sonnet-4-20250514

# --- 自定义端点 ---
# 覆盖平台预设的 API 端点（配合任意 model_provider）
# CLAWAGENT_API_BASE=https://your-custom-endpoint.com/v1
# CLAWAGENT_MODEL_PROVIDER=openai


# ─── 3. Worker 配置（混合模式）─────────────────────────────
#
# 每个 Worker 是独立的临时 Agent，执行委托的子任务。
# 未显式配置的 Worker → 继承主 Agent 的平台/端点/密钥
# 显式配置的 Worker → 完整覆盖（可走不同平台降低成本）
#
# 角色：coder / researcher / critic / writer

# 通用默认值（所有 Worker 的回退）
WORKER_COMMON_MODEL=deepseek-v4-flash
WORKER_COMMON_MODEL_PROVIDER=openai
# WORKER_COMMON_API_KEY=           # 回退到 CLAWAGENT_API_KEY
# WORKER_COMMON_API_BASE=          # 回退到主平台端点
# WORKER_COMMON_MAX_TOKENS=4096
# WORKER_COMMON_TEMPERATURE=0.0
# WORKER_COMMON_REQUEST_TIMEOUT=120

# Coder Worker（代码编写/调试 — 继承主平台 DeepSeek）
# WORKER_CODER_MODEL=deepseek-v4-flash

# Researcher Worker（联网搜索 — 独立走 SiliconFlow 降本）
# WORKER_RESEARCHER_MODEL=Qwen/Qwen3.5-35B-A3B
# WORKER_RESEARCHER_MODEL_PROVIDER=openai
# WORKER_RESEARCHER_API_BASE=https://api.siliconflow.cn/v1
# WORKER_RESEARCHER_API_KEY=sk-siliconflow-key

# Critic Worker（代码审查 — 独立走 SiliconFlow 降本）
# WORKER_CRITIC_MODEL=Qwen/Qwen3.5-35B-A3B
# WORKER_CRITIC_MODEL_PROVIDER=openai
# WORKER_CRITIC_API_BASE=https://api.siliconflow.cn/v1
# WORKER_CRITIC_API_KEY=sk-siliconflow-key

# Writer Worker（文档/创作 — 继承主平台 DeepSeek）
# WORKER_WRITER_MODEL=deepseek-v4-flash


# ─── 4. 记忆系统 ──────────────────────────────────────────
#
# 两层记忆：
#   - 工作记忆：当前会话上下文（LangGraph checkpointer）
#   - 长期记忆：偏好 + 用户画像 + 关键事实 + 会话摘要，每 10 轮后台提取
# 全部存储在本地 SQLite（不上云）。
# 使用 /forget all 清除记忆。

# SQLite 数据库路径
# CLAWAGENT_MEMORY_DB=memories/sessions.db

# 注入提示词的最大偏好数量
# CLAWAGENT_MAX_PREFERENCES=5

# 隐私分级（新提取记忆的默认级别）：
#   public     — 项目/技术内容，完全可用
#   sensitive  — 个人偏好、工作背景，存 SQLite 但不可外传
#   private    — 密码/密钥，不存储
# CLAWAGENT_MEMORY_PRIVACY_DEFAULT=public


# ─── 5. 安全与权限 ────────────────────────────────────────
#
# 工具级三级权限控制（可用 /permissions 命令动态调整）：
#   ALLOW    — 自动执行（读文件、RAG 检索）
#   CONFIRM  — 弹出确认提示后执行（写源码、git push）
#   DENY     — 直接拒绝（写 .env、rm 命令）
#
# 默认规则 28 条，Worker 有额外限制（Researcher/Critic 禁写文件和执行命令）

# 跳过 CONFIRM 确认提示（非交互模式下仍拒绝）
# CLAWAGENT_AUTO_CONFIRM=true

# 审计日志路径（JSONL 格式，超 10 MB 自动轮转）
# CLAWAGENT_AUDIT_LOG=logs/audit.jsonl

# Worker 委托结果最大字符数（超长截断，避免撑爆上下文）
# CLAWAGENT_MAX_RESULT_CHARS=50000


# ─── 6. 上下文压缩 ────────────────────────────────────────
#
# 长对话时压缩历史消息，避免超出上下文窗口。
# 策略：trim（保留最近 N 条）/ token_trim（Token 预算）/ summarize（LLM 摘要）

# COMPRESSION_STRATEGY=trim
# COMPRESSION_MAX_MESSAGES=40
# COMPRESSION_MAX_TOKENS=80000
# COMPRESSION_KEEP_RECENT=6
# COMPRESSION_SUMMARY_TIMEOUT=30


# ─── 7. 网关模式 ──────────────────────────────────────────
#
# 多渠道事件循环，同时运行 CLI 和微信渠道。
# 启动：uv run clawagent gateway

# CLI 渠道
# GATEWAY_ENABLE_CLI=true

# 微信 iLink Bot（需 weixin-ilink 依赖）
# 首次运行显示终端二维码，扫码登录，凭据保存到 ilink_creds.json
# WECHAT_ILINK_ENABLED=true
# WECHAT_ILINK_CREDS=ilink_creds.json

# 渠道独立模型配置（管道分隔：model|provider|key|base|temp|max_tokens）
# CHANNEL_MODEL_WECHAT=deepseek-v4-pro|openai||||


# ─── 8. RAG 混合检索 ──────────────────────────────────────
#
# KNN 向量检索 + BM25 词法匹配，RRF 融合。
# 需 SiliconFlow embedding API（可选，不配则只保留 BM25 回退）。

# SILICONFLOW_API_KEY=sk-siliconflow-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/embeddings
# SILICONFLOW_MODEL=Qwen/Qwen3-VL-Embedding-8B
# SILICONFLOW_DIMENSIONS=768

# BM25 索引缓存 HMAC 签名密钥（空 = 不签名，缓存仍可用但未验证）
# CLAWAGENT_BM25_CACHE_SECRET=your-random-secret-here


# ─── 9. 高级设置 ──────────────────────────────────────────

# Agent ID（读取 prompts/agents/<id>/identity.md 和 soul.md）
# CLAWAGENT_AGENT_ID=wenbao

# 上下文窗口大小（仅用于 UI 百分比显示，不影响实际 LLM 调用）
# CLAWAGENT_CONTEXT_WINDOW=1000000

# API 请求超时（秒）
# CLAWAGENT_REQUEST_TIMEOUT=120


# ─── 10. 未来扩展（planned）────────────────────────────────
#
# 以下功能尚未实现，预留配置接口。

# --- Web UI (planned) ---
# 浏览器管理界面：对话监控、审计日志查看、权限配置
# ETA: TBD
# CLAWAGENT_WEBUI_ENABLED=false
# CLAWAGENT_WEBUI_PORT=8080
# CLAWAGENT_WEBUI_AUTH_TOKEN=

# --- Plugin System (planned) ---
# 第三方工具/Worker 插件，动态加载，社区贡献
# ETA: TBD
# CLAWAGENT_PLUGIN_DIR=plugins/
# CLAWAGENT_PLUGINS=

# --- Remote Deployment (planned) ---
# Docker / 云端一键部署
# ETA: TBD
# CLAWAGENT_DEPLOY_MODE=standalone
# CLAWAGENT_DEPLOY_PORT=8000

# --- MCP Server Mode (planned) ---
# 作为 MCP Server 暴露工具和 Agent 能力给其他 AI Agent 调用
# ETA: TBD
# CLAWAGENT_MCP_ENABLED=false
# CLAWAGENT_MCP_PORT=3100
# CLAWAGENT_MCP_AUTH_TOKEN=


# ════════════════════════════════════════════════════════════
# 完整环境变量参考
# ════════════════════════════════════════════════════════════
#
# 变量名                           默认值                     说明
# ──────────────────────────────── ───────────────────────── ──────────────────────
# CLAWAGENT_API_KEY                (必填)                     API 密钥（所有平台回退）
# CLAWAGENT_PLATFORM               deepseek                  平台：deepseek|ark|opencode-go|openai|anthropic
# CLAWAGENT_MODEL                  deepseek-v4-flash         模型名称
# CLAWAGENT_MODEL_PROVIDER         openai                    LangChain provider
# CLAWAGENT_API_BASE               (平台预设)                自定义 API 端点（覆盖平台预设）
# CLAWAGENT_AGENT_ID               wenbao                    Agent 身份
# CLAWAGENT_CONTEXT_WINDOW         1000000                   上下文窗口（仅 UI 显示）
# CLAWAGENT_MEMORY_DB              memories/sessions.db      SQLite 记忆数据库
# CLAWAGENT_MAX_PREFERENCES        5                         注入的最大偏好数
# CLAWAGENT_MEMORY_PRIVACY_DEFAULT public                    默认隐私级别
# CLAWAGENT_MAX_RESULT_CHARS       50000                     Worker 结果最大字符数
# CLAWAGENT_REQUEST_TIMEOUT        120                       API 请求超时（秒）
# CLAWAGENT_AUTO_CONFIRM           false                     跳过 CONFIRM 确认提示
# CLAWAGENT_AUDIT_LOG              logs/audit.jsonl          审计日志路径
# CLAWAGENT_BM25_CACHE_SECRET      (空)                      BM25 缓存 HMAC 密钥
#
# COMPRESSION_STRATEGY             trim                      压缩策略
# COMPRESSION_MAX_MESSAGES         40                        最大消息数
# COMPRESSION_MAX_TOKENS           80000                     Token 阈值
# COMPRESSION_KEEP_RECENT          6                         保留最近消息数
# COMPRESSION_SUMMARY_TIMEOUT      30                        摘要超时（秒）
#
# SILICONFLOW_API_KEY              (空)                      embedding API 密钥
# SILICONFLOW_BASE_URL             https://api.siliconfl...  embedding API 端点
# SILICONFLOW_MODEL                Qwen/Qwen3-VL-Embeddi...  embedding 模型
# SILICONFLOW_DIMENSIONS           768                       embedding 维度
#
# GATEWAY_ENABLE_CLI               true                      CLI 渠道开关
# WECHAT_ILINK_ENABLED             false                     微信渠道开关
# WECHAT_ILINK_CREDS               ilink_creds.json          微信凭据文件
# CHANNEL_MODEL_<CHANNEL>          (空)                      渠道独立模型配置
#
# WORKER_COMMON_MODEL              deepseek-v4-flash         Worker 通用模型
# WORKER_COMMON_MODEL_PROVIDER     openai                    Worker 通用 provider
# WORKER_COMMON_MAX_TOKENS         4096                      Worker 通用 max_tokens
# WORKER_COMMON_TEMPERATURE        0.0                       Worker 通用 temperature
# WORKER_COMMON_REQUEST_TIMEOUT    120                       Worker 通用超时
# WORKER_<ROLE>_MODEL              (继承 COMMON)             角色模型
# WORKER_<ROLE>_MODEL_PROVIDER     (继承 COMMON)             角色 provider
# WORKER_<ROLE>_API_BASE           (继承主平台)              角色 API 端点
# WORKER_<ROLE>_API_KEY            (继承主平台)              角色 API 密钥
# WORKER_<ROLE>_MAX_TOKENS         (继承 COMMON)             角色 max_tokens
# WORKER_<ROLE>_TEMPERATURE        (继承 COMMON)             角色 temperature
